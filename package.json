{
  "name": "copy-of-hirakata-care-manager-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-all.mjs",
    "typecheck": "tsc --noEmit",
    "build:member": "vite build",
    "build:public": "node -e \"process.env.VITE_APP='public'\" && vite build",
    "build:preview": "vite build --mode preview",
    "preview": "vite preview",
    "build:gas": "node scripts/build-gas.mjs",
    "build:gas:member": "node scripts/build-member-gas.mjs",
    "build:gas:admin": "node scripts/build-admin-gas.mjs",
    "clasp:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-clasp.ps1",
    "clasp:login": "clasp login",
    "clasp:push": "npm run build:gas && clasp push",
    "clasp:deploy": "node -e \"console.error('ERROR: clasp deploy is prohibited. Use Manage Deployments UI after clasp version. See docs/09_DEPLOYMENT_POLICY.md.'); process.exit(1)\"",
    "security:audit": "npm audit --audit-level=high",
    "security:secrets": "git log --diff-filter=A --name-only --pretty=format: | grep -E '\\.(env|pem|key|secret|credentials)$' || true",
    "prerelease": "npm run security:audit && npm run typecheck"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@google/clasp": "^3.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
